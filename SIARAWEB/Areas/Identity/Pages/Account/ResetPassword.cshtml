@page
@model ResetPasswordModel
@{
    ViewData["Title"] = "Restablecer Contraseña";
    ViewData["OcultarMenu"] = true;
}

<!-- 1. ENCABEZADO PRINCIPAL -->
<header class="siara-header">
    <img src="~/img/tecnm_logo.png" alt="TecNM" class="logo-header" />
    <div class="siara-header-text">
        <h1>TECNOLOGICO NACIONAL DE MEXICO</h1>
        <h2>Sistema Integral de Análisis y Reportes Académicos</h2>
    </div>
    <img src="~/img/instituto_logo.png" alt="ITC" class="logo-header" />
</header>

<div class="login-wrapper">
    <div class="tarjeta-siara">
        <!-- 2. LOGO DEL SISTEMA -->
        <img src="~/img/siara_logo.png" alt="S.I.A.R.A" class="logo-siara-centro" />
        
        <!-- 3. TEXTO DE RECUPERAR CONTRASEÑA -->
        <h3 class="titulo-pantalla">RECUPERAR CONTRASEÑA</h3> 

        <form method="post">
            <div asp-validation-summary="ModelOnly" class="texto-error"></div>
            
            <!-- Estos campos ocultos son obligatorios en ASP.NET para vincular la clave al correo -->
            <input asp-for="Input.Code" type="hidden" />
            <input asp-for="Input.Email" type="hidden" />

            <!-- 4. CASILLA PARA ESCRIBIR LA CONTRASEÑA NUEVA -->
            <div class="grupo-input">
                <svg class="icono-input" viewBox="0 0 24 24">
                    <path d="M18 8h-1V6c0-2.76-2.24-5-5-5S7 3.24 7 6v2H6c-1.1 0-2 .9-2 2v10c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V10c0-1.1-.9-2-2-2zm-6 9c-1.1 0-2-.9-2-2s.9-2 2-2 2 .9 2 2-.9 2-2 2z" />
                </svg>
                <input asp-for="Input.Password" class="input-siara" autocomplete="new-password" style="font-size: 12px;" placeholder="INGRESA UNA CONTRASEÑA NUEVA" /> <!--[cite: 1] -->
                <span asp-validation-for="Input.Password" class="texto-error"></span>
            </div>

            <!-- Confirmación de contraseña (Requerido por ASP.NET) -->
            <div class="grupo-input">
                <svg class="icono-input" viewBox="0 0 24 24">
                    <path d="M18 8h-1V6c0-2.76-2.24-5-5-5S7 3.24 7 6v2H6c-1.1 0-2 .9-2 2v10c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V10c0-1.1-.9-2-2-2zm-6 9c-1.1 0-2-.9-2-2s.9-2 2-2 2 .9 2 2-.9 2-2 2z" />
                </svg>
                <input asp-for="Input.ConfirmPassword" class="input-siara" autocomplete="new-password" style="font-size: 12px;" placeholder="CONFIRMAR CONTRASEÑA" />
                <span asp-validation-for="Input.ConfirmPassword" class="texto-error"></span>
            </div>

            <div class="contenedor-botones-columna">
                <!-- 5. CASILLA PARA GUARDAR LOS CAMBIOS -->
                <button type="submit" class="btn-siara" style="width: 70%;">GUARDAR</button> 
                <!-- 6. BOTON PARA CANCELAR LOS CAMBIOS -->
                <a asp-page="./Login" class="btn-siara" style="width: 70%;">CANCELAR</a> 
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}