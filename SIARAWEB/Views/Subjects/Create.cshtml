@model SIARAWEB.Models.Subject

@{
    ViewData["Title"] = "Crear Asignatura";
}

<h3 style="color: #0b2353; font-weight: bold;">AGREGAR NUEVA ASIGNATURA</h3>
<hr />
<div class="row">
    <div class="col-md-6">
        <form asp-action="Create">
            <!-- ESTA LÍNEA ES LA MAGIA: Si hay algún error oculto, lo escribirá aquí en rojo -->
            <div asp-validation-summary="All" class="text-danger fw-bold mb-3"></div>

            <div class="form-group mb-3">
                <label asp-for="Clave" class="control-label fw-bold">Clave de la Materia</label>
                <input asp-for="Clave" class="form-control" placeholder="Ej. H1B63" />
            </div>

            <div class="form-group mb-3">
                <label asp-for="Name" class="control-label fw-bold">Nombre de la Asignatura</label>
                <input asp-for="Name" class="form-control" placeholder="Ej. Desarrollo Sustentable" />
            </div>

            <div class="row">
                <div class="form-group col-md-6 mb-3">
                    <label asp-for="Horas" class="control-label fw-bold">Horas por Semana</label>
                    <input asp-for="Horas" class="form-control" type="number" />
                </div>

                <div class="form-group col-md-6 mb-3">
                    <label asp-for="Temas" class="control-label fw-bold">Cantidad de Temas</label>
                    <input asp-for="Temas" class="form-control" type="number" />
                </div>
            </div>

            <div class="row">
                <div class="form-group col-md-6 mb-3">
                    <label asp-for="Period" class="control-label fw-bold">Semestre</label>
                    <input asp-for="Period" class="form-control" placeholder="Ej. 6TO SEMESTRE" />
                </div>

                <div class="form-group col-md-6 mb-4">
                    <label asp-for="Year" class="control-label fw-bold">Año</label>
                    <input asp-for="Year" class="form-control" type="number" value="2026" />
                </div>
            </div>

            <div class="form-group">
                <a asp-action="Index" class="btn btn-secondary me-2">REGRESAR</a>
                <input type="submit" value="GUARDAR ASIGNATURA" class="btn btn-primary" style="background-color: #0b2353;" />
            </div>
        </form>
    </div>
</div>