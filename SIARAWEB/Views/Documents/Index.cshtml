@model IEnumerable<SIARAWEB.Models.Document>

@{
    ViewData["Title"] = "Monitoreo de Documentos";
    Layout = "_Layout";
}

<style>
        .container {
            max-width: 100% !important;
            padding: 0 !important;
        }

        main {
            padding-bottom: 0 !important;
        }
</style>

<link rel="stylesheet" href="~/css/estilos.css" />

<div style="background-color: #f9f9f9; padding-bottom: 30px; min-height: 100vh; width: 100%;">

    <header class="siara-header" style="margin: 0 0 25px 0;">
        <img src="~/img/tecnm_logo.png" alt="TecNM" class="logo-header" />
        <div class="siara-header-text">
            <h1 style="color: white; margin: 0;">TECNOLÓGICO NACIONAL DE MÉXICO</h1>
            <h2 style="color: white; margin: 5px 0 0 0;">Sistema Integral de Análisis y Reportes Académicos</h2>
        </div>
        <img src="~/img/instituto_logo.png" alt="ITC" class="logo-header" />
    </header>

    <div style="padding: 0 40px;">
        
        <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 20px;">
            
            <div style="width: 32%;">
                <div style="color: #112d60; font-weight: 900; margin-bottom: 2px; text-transform: uppercase; font-size: 14px;">CARRERA:</div>
                <div style="border: 2px solid #000; padding: 5px 10px; font-weight: bold; text-transform: uppercase; font-size: 13px; color: #000; background-color: white;">Ing. en sistemas computacionales</div>
                
                <div style="color: #112d60; font-weight: 900; margin-bottom: 2px; text-transform: uppercase; font-size: 14px; margin-top: 15px;">DEPARTAMENTO:</div>
                <div style="border: 2px solid #000; padding: 5px 10px; font-weight: bold; text-transform: uppercase; font-size: 13px; color: #000; max-width: 250px; background-color: white;">SISTEMAS Y COMPUTACION</div>
            </div>

            <div style="width: 32%; text-align: center;">
                <h4 style="font-weight: 900; color: #000; margin-bottom: 25px; font-size: 16px;">VISTA DEL ADMINISTRADOR</h4>
                <div style="color: #112d60; font-weight: 900; margin-bottom: 2px; text-transform: uppercase; font-size: 14px; text-align: left;">SEMESTRE Y AÑO:</div>
                <div style="border: 2px solid #000; padding: 5px 10px; font-weight: bold; text-transform: uppercase; font-size: 13px; color: #000; background-color: white;">ENERO - JUNIO 26</div>
            </div>

            <div style="width: 32%;">
                <div style="display: flex; gap: 15px; justify-content: flex-end; margin-bottom: 25px;">
                    <a asp-controller="AcademicTrackings" asp-action="Index" class="btn-siara-3d" style="padding: 5px 25px !important; text-transform: none !important;">Regresar</a>
                    <a asp-action="Create" class="btn-siara-3d" style="padding: 5px 15px !important;">AGREGAR</a>
                </div>
                <div style="color: #112d60; font-weight: 900; margin-bottom: 2px; text-transform: uppercase; font-size: 14px; text-align: center;">RESPONSABLE DE SEGUIMIENTO:</div>
                <div style="border: 2px solid #000; padding: 5px 10px; font-weight: bold; text-transform: uppercase; font-size: 13px; color: #000; text-align: center; background-color: white;">JOSE RAMON CAB CHAN</div>
            </div>
        </div>

        <div style="border: 2px solid #000; background-color: white; text-align: center; font-weight: 900; color: #112d60; padding: 10px; margin-bottom: 20px; font-size: 18px;">
            MONITOREO DE DOCUMENTOS INICIALES
        </div>

        <div style="display: flex; gap: 30px; align-items: flex-start;">
            
            <div style="flex: 1;">
                <table class="tabla-dashboard" style="border: 2px solid #000; background-color: white; width: 100%;">
                    <thead>
                        <tr>
                            <th style="border: 2px solid #000; background-color: #112d60; color: white !important; font-size: 13px; width: 25%; text-align: center; padding: 10px;">ASIGNATURA</th>
                            <th style="border: 2px solid #000; background-color: #112d60; color: white !important; font-size: 13px; width: 25%; text-align: center; padding: 10px;">OBSERVACIONES</th>
                            <th style="border: 2px solid #000; background-color: #112d60; color: white !important; font-size: 13px; width: 20%; text-align: center; padding: 10px;">FECHA Y HORA<br>DE ENTREGA</th>
                            <th style="border: 2px solid #000; background-color: #112d60; color: white !important; font-size: 13px; width: 15%; text-align: center; padding: 10px;">ESTATUS</th>
                            <th style="border: 2px solid #000; background-color: #112d60; color: white !important; font-size: 13px; width: 15%; text-align: center; padding: 10px;">ACCIONES</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var item in Model)
                            {
                                <tr>
                                    <td style="border: 1px solid #ccc; font-weight: 900; text-transform: uppercase; text-align: center; padding: 10px;">
                                        @Html.DisplayFor(modelItem => item.Subject.Name)
                                    </td>
                                    
                                    <td style="border: 1px solid #ccc; font-size: 13px; padding: 10px; text-align: center;">
                                        @Html.DisplayFor(modelItem => item.Observaciones)
                                    </td>
                                    
                                    <td style="border: 1px solid #ccc; font-weight: 900; font-size: 13px; color: #112d60; text-align: center; padding: 10px;">
                                        @item.UploadedAt.ToString("dd/MM/yyyy, HH:mm 'HRS'")
                                    </td>
                                    
                                    <td style="border: 1px solid #ccc; text-align: center; padding: 10px;">
                                        @if (item.IsOnTime)
                                        {
                                            <svg width="30" height="30" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10" fill="#4caf50" /><path d="M9 16.2L4.8 12l-1.4 1.4L9 19 21 7l-1.4-1.4L9 16.2z" fill="white" /></svg>
                                        }
                                        else
                                        {
                                            <span style="color: #d9534f; font-weight: 900; font-size: 11px;">FUERA DE TIEMPO ⚠</span>
                                        }
                                    </td>
                                    
                                    <td style="border: 1px solid #ccc; text-align: center; padding: 10px;">
                                        <div style="display: flex; justify-content: center; gap: 12px;">
                                            <a asp-action="Details" asp-route-id="@item.Id" style="color: #112d60; text-decoration: none;" title="Visualizar">
                                                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path><circle cx="12" cy="12" r="3"></circle></svg>
                                            </a>
                                            <a asp-action="Edit" asp-route-id="@item.Id" style="color: #f0ad4e; text-decoration: none; font-size: 18px;" title="Editar">&#9998;</a>
                                            <a asp-action="Delete" asp-route-id="@item.Id" style="color: #d9534f; text-decoration: none; font-size: 18px;" title="Eliminar">&#128465;</a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr><td colspan="5" style="border: 1px solid #ccc; padding: 20px; text-align: center;">No hay documentos registrados.</td></tr>
                        }
                    </tbody>
                </table>
            </div>

            <div style="width: 250px; display: flex; flex-direction: column; gap: 25px; padding-top: 15px;">
                <div style="display: flex; align-items: center; gap: 15px; font-weight: 900; color: #112d60; font-size: 13px;">
                    <svg width="30" height="30" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10" fill="#4caf50" /><path d="M9 16.2L4.8 12l-1.4 1.4L9 19 21 7l-1.4-1.4L9 16.2z" fill="white" /></svg>
                    <span>ENTREGADO EN TIEMPO Y FORMA</span>
                </div>
                <div style="display: flex; align-items: center; gap: 15px; font-weight: 900; color: #112d60; font-size: 13px;">
                    <svg width="30" height="30" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10" fill="#e0e0e0" stroke="#000" stroke-width="2" /><path d="M12 7v5l3 3" stroke="#000" stroke-width="2" fill="none" /></svg>
                    <span>ENTREGADO EN TIEMPO</span>
                </div>
                <div style="display: flex; align-items: center; gap: 15px; font-weight: 900; color: #d9534f; font-size: 13px; padding-left: 45px;">
                    <span>FUERA DE TIEMPO</span>
                </div>
            </div>

        </div>
    </div>
</div>