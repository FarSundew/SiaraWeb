@model SIARAWEB.Models.Document

@{
    ViewData["Title"] = "Subir Documentos Iniciales";
}

<h3 style="color: #0b2353; font-weight: bold;">DOCUMENTOS INICIALES</h3>
<hr />
<div class="row">
    <div class="col-md-8">
        <!-- IMPORTANTE: enctype="multipart/form-data" permite enviar los archivos al backend -->
        <form asp-action="Create" enctype="multipart/form-data">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-group mb-3">
                <label asp-for="SubjectId" class="control-label fw-bold">Asignatura</label>
                <!-- Este menú desplegable mostrará las materias disponibles -->
                <select asp-for="SubjectId" class="form-select" asp-items="ViewBag.SubjectId"></select>
            </div>

            <div class="form-group mb-3">
                <label class="control-label">Instrumentación Didáctica</label>
                <input type="file" name="instrumentacionFile" class="form-control" accept=".pdf,.doc,.docx,.xls,.xlsx" />
            </div>

            <div class="form-group mb-3">
                <label class="control-label">Instrumento de Evaluación</label>
                <input type="file" name="evaluacionFile" class="form-control" accept=".pdf,.doc,.docx,.xls,.xlsx" />
            </div>

            <div class="form-group mb-3">
                <label class="control-label">Práctica de Laboratorio</label>
                <input type="file" name="practicaFile" class="form-control" accept=".pdf,.doc,.docx,.xls,.xlsx" />
            </div>

            <div class="form-group mb-3">
                <label class="control-label">Proyecto Individual</label>
                <input type="file" name="proyectoFile" class="form-control" accept=".pdf,.doc,.docx,.xls,.xlsx" />
            </div>

            <div class="form-group mb-4">
                <label asp-for="Observaciones" class="control-label fw-bold">Observaciones</label>
                <textarea asp-for="Observaciones" class="form-control" rows="3"></textarea>
            </div>

            <div class="form-group">
                <a asp-action="Index" class="btn btn-secondary me-2">REGRESAR</a>
                <input type="submit" value="SIGUIENTE (Guardar)" class="btn btn-primary" style="background-color: #0b2353;" />
            </div>
        </form>
    </div>
</div>