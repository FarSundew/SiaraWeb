@model SIARAWEB.Models.Document

@{
    ViewData["Title"] = "Editar Documentos";
    Layout = "_Layout";

    string MostrarIconoActual(string? path, string nombreCampo)
    {
        if (string.IsNullOrEmpty(path)) return "";
        
        string ext = System.IO.Path.GetExtension(path)?.ToLower() ?? "";
        string color = "#757575";
        string texto = "FILE";

        if (ext == ".pdf") { color = "#d32f2f"; texto = "PDF"; }
        else if (ext == ".xls" || ext == ".xlsx") { color = "#2e7d32"; texto = "XLS"; }
        else if (ext == ".doc" || ext == ".docx") { color = "#1565c0"; texto = "DOC"; }

        return $@"
        <div style='display: flex; justify-content: center; align-items: center; gap: 15px; margin-bottom: 12px;'>
            <div style='text-align: center;'>
                <a href='{path}' target='_blank' title='Ver archivo actual' style='text-decoration: none;'>
                    <svg width='28' height='28' viewBox='0 0 24 24' fill='{color}'><path d='M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z'></path><polyline points='14 2 14 8 20 8' fill='none' stroke='white' stroke-width='2'></polyline><text x='8' y='16' fill='white' font-family='Arial' font-size='6' font-weight='bold'>{texto}</text></svg>
                </a>
                <span style='display: block; font-size: 10px; font-weight: bold; color: #112d60; margin-top: 2px;'>Ya subido</span>
            </div>
            <div style='text-align: center;'>
                <label style='cursor: pointer; display: flex; flex-direction: column; align-items: center;' title='Marcar para eliminar'>
                    <input type='checkbox' name='Remove{nombreCampo}' value='true' style='margin-bottom: 2px; cursor: pointer;' />
                    <svg width='22' height='22' viewBox='0 0 24 24' fill='none' stroke='#d9534f' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'><polyline points='3 6 5 6 21 6'></polyline><path d='M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2'></path><line x1='10' y1='11' x2='10' y2='17'></line><line x1='14' y1='11' x2='14' y2='17'></line></svg>
                    <span style='font-size: 10px; font-weight: bold; color: #d9534f; margin-top: 2px;'>Eliminar</span>
                </label>
            </div>
        </div>";
    }
}

<style>
    .container {
        max-width: 100% !important;
        padding: 0 !important;
    }

    main {
        padding-bottom: 0 !important;
    }
</style>

<link rel="stylesheet" href="~/css/estilos.css" />

<div style="background-color: #f9f9f9; padding-top: 25px; padding-bottom: 30px; min-height: 100vh; width: 100%;">

    <div style="padding: 0 40px;">
        <form asp-action="Edit" enctype="multipart/form-data">
            
            <div asp-validation-summary="ModelOnly" class="text-danger" style="padding: 0 30px;"></div>
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="InstrumentacionPath" />
            <input type="hidden" asp-for="EvaluacionPath" />
            <input type="hidden" asp-for="PracticaPath" />
            <input type="hidden" asp-for="ProyectoPath" />
            <input type="hidden" asp-for="UploadedAt" />
            <input type="hidden" asp-for="IsOnTime" />

            <div style="display: flex; justify-content: flex-end; align-items: center; margin-bottom: 25px; gap: 20px;">
                <div style="display: flex; gap: 15px;">
                    <a asp-action="Index" class="btn-siara-3d" style="padding: 6px 25px !important; text-transform: none !important;">Regresar</a>
                    <button type="submit" class="btn-siara-3d" style="padding: 6px 25px !important; text-transform: none !important;">Guardar Cambios</button>
                </div>
                
                <div style="display: flex; align-items: center; gap: 10px;">
                    <svg width="28" height="28" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10" fill="#4caf50" /><path d="M9 16.2L4.8 12l-1.4 1.4L9 19 21 7l-1.4-1.4L9 16.2z" fill="white" /></svg>
                    <h3 style="font-weight: 900; color: #000; margin: 0; font-size: 18px;">VISTA DEL MAESTRO</h3>
                </div>
            </div>

            <div style="border: 2px solid #ccc; background-color: white; text-align: center; font-weight: 900; color: #112d60; padding: 10px; margin-bottom: 20px; font-size: 16px;">
                DOCUMENTOS INICIALES
            </div>

            <div style="width: 100%; overflow-x: auto;">
                <table class="tabla-dashboard" style="border: 2px solid #ccc; background-color: white; width: 100%; border-collapse: collapse;">
                    <thead>
                        <tr>
                            <th style="border: 2px solid #ccc; background-color: white; color: #112d60 !important; font-size: 12px; text-align: center; padding: 10px; width: 15%;">ASIGNATURA</th>
                            <th style="border: 2px solid #ccc; background-color: white; color: #112d60 !important; font-size: 12px; text-align: center; padding: 10px; width: 17%;">Instrumentacion<br>Didactica</th>
                            <th style="border: 2px solid #ccc; background-color: white; color: #112d60 !important; font-size: 12px; text-align: center; padding: 10px; width: 17%;">Instrumento de<br>evaluacion</th>
                            <th style="border: 2px solid #ccc; background-color: white; color: #112d60 !important; font-size: 12px; text-align: center; padding: 10px; width: 17%;">Practica<br>Laboratorio</th>
                            <th style="border: 2px solid #ccc; background-color: white; color: #112d60 !important; font-size: 12px; text-align: center; padding: 10px; width: 17%;">Proyecto<br>Individual</th>
                            <th style="border: 2px solid #ccc; background-color: white; color: #112d60 !important; font-size: 12px; text-align: center; padding: 10px; width: 17%;">Observaciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td style="border: 2px solid #ccc; text-align: center; padding: 15px; vertical-align: top;">
                                <select asp-for="SubjectId" class="form-control" style="font-size: 12px; font-weight: bold; border: 2px solid #112d60; text-transform: uppercase;" asp-items="ViewBag.SubjectId"></select>
                                <span class="text-muted" style="font-size: 9px; display: block; margin-top: 5px;">La fecha original no se modifica.</span>
                            </td>

                            <td style="border: 2px solid #ccc; text-align: center; padding: 15px; vertical-align: top;">
                                @Html.Raw(MostrarIconoActual(Model?.InstrumentacionPath, "Instrumentacion"))
                                <input type="file" name="instrumentacionFile" class="form-control" style="font-size: 10px; margin-top: 5px;" accept=".pdf,.doc,.docx,.xls,.xlsx" />
                            </td>

                            <td style="border: 2px solid #ccc; text-align: center; padding: 15px; vertical-align: top;">
                                @Html.Raw(MostrarIconoActual(Model?.EvaluacionPath, "Evaluacion"))
                                <input type="file" name="evaluacionFile" class="form-control" style="font-size: 10px; margin-top: 5px;" accept=".pdf,.doc,.docx,.xls,.xlsx" />
                            </td>

                            <td style="border: 2px solid #ccc; text-align: center; padding: 15px; vertical-align: top;">
                                @Html.Raw(MostrarIconoActual(Model?.PracticaPath, "Practica"))
                                <input type="file" name="practicaFile" class="form-control" style="font-size: 10px; margin-top: 5px;" accept=".pdf,.doc,.docx,.xls,.xlsx" />
                            </td>

                            <td style="border: 2px solid #ccc; text-align: center; padding: 15px; vertical-align: top;">
                                @Html.Raw(MostrarIconoActual(Model?.ProyectoPath, "Proyecto"))
                                <input type="file" name="proyectoFile" class="form-control" style="font-size: 10px; margin-top: 5px;" accept=".pdf,.doc,.docx,.xls,.xlsx" />
                            </td>

                            <td style="border: 2px solid #ccc; text-align: center; padding: 15px; vertical-align: top;">
                                <textarea asp-for="Observaciones" class="form-control" rows="4" style="font-size: 12px; border: 2px solid #112d60;"></textarea>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>

        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}