@model IEnumerable<SIARAWEB.Models.ApplicationUser>

<div class="container mt-4">
    <h2>Lista de Docentes</h2>
    <hr />

    <div class="mb-3">
        <a asp-action="Create" class="btn btn-success">Registrar Nuevo Docente</a>
    </div>

    <table class="table table-striped table-hover table-bordered">
        <thead class="table-dark">
            <tr>
                <th>Nombre Completo</th>
                <th>Correo Institucional</th>
                <th>CURP</th>
                <th>RFC</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
            <!-- Aquí validamos si la lista que envió el controlador está vacía -->
            @if (!Model.Any())
            {
                <tr>
                    <td colspan="5" class="text-center text-muted py-4">
                        No hay docentes registrados en el sistema aún.
                    </td>
                </tr>
            }
            else
            {
                // Si hay datos, los recorremos uno por uno
                foreach (var item in Model)
                {
                    <tr>
                        <td class="align-middle">@item.Name</td>
                        <td class="align-middle">@item.Email</td>
                        <td class="align-middle">@item.Curp</td>
                        <td class="align-middle">@item.Rfc</td>
                        <td class="align-middle text-center">
                            <!-- Botón para Editar (Cumpliendo el RF05) -->
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Editar</a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Eliminar</a>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>