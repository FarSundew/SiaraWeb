@model SIARAWEB.ViewModel.DocenteEditViewModel
@* Nota: Usa SIARAWEB.ViewModels si guardaste el modelo en la carpeta ViewModels *@

<div class="container mt-4">
    <h2>Editar Datos del Docente</h2>
    <hr />

    <form asp-action="Edit" method="post">
        <!-- Campo oculto indispensable para no perder el ID del usuario -->
        <input type="hidden" asp-for="Id" />

        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        <div class="form-group mb-3">
            <label asp-for="Name" class="control-label">Nombre Completo</label>
            <input asp-for="Name" class="form-control" />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>

        <div class="form-group mb-3">
            <label asp-for="Curp" class="control-label">CURP</label>
            <input asp-for="Curp" class="form-control" />
            <span asp-validation-for="Curp" class="text-danger"></span>
        </div>

        <div class="form-group mb-3">
            <label asp-for="Rfc" class="control-label">RFC</label>
            <input asp-for="Rfc" class="form-control" />
            <span asp-validation-for="Rfc" class="text-danger"></span>
        </div>

        <div class="form-group mb-3">
            <label asp-for="Email" class="control-label">Correo Institucional</label>
            <input asp-for="Email" class="form-control" />
            <span asp-validation-for="Email" class="text-danger"></span>
        </div>

        <div class="mt-4">
            <button type="submit" class="btn btn-warning">Guardar Cambios</button>
            <a asp-action="Index" class="btn btn-secondary">Cancelar y volver a la lista</a>
        </div>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}