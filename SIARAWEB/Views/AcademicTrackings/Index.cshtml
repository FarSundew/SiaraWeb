@model IEnumerable<SIARAWEB.Models.AcademicTracking>

@{
    ViewData["Title"] = "Cursos y Docentes";
    Layout = "_Layout";
}

<style>
    .container {
        max-width: 100% !important;
        padding: 0 !important;
    }

    main {
        padding-bottom: 0 !important;
    }
</style>

<link rel="stylesheet" href="~/css/estilos.css" />

<div style="background-color: #f4f6f9; padding-top: 25px; padding-bottom: 40px; min-height: 100vh; width: 100%;">

    <div style="padding: 0 40px; width: 100%;">

        <h2 style="text-align: center; font-weight: 900; margin-bottom: 15px; color: #000; text-transform: uppercase;">
            CURSOS Y DOCENTES
        </h2>
        
        <div style="background-color: #f2f3f5; padding: 30px; border-radius: 20px; width: 100%; box-shadow: 0px 5px 15px rgba(0,0,0,0.15);">
            
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
                <div style="display: flex; gap: 15px; flex-wrap: wrap;">
                    <a href="#" class="btn-pildora-dashboard">
                        <svg style="width: 16px; fill: white;" viewBox="0 0 24 24"><path d="M12 4.5C7 4.5 2.73 7.61 1 12c1.73 4.39 6 7.5 11 7.5s9.27-3.11 11-7.5c-1.73-4.39-6-7.5-11-7.5zM12 17c-2.76 0-5-2.24-5-5s2.24-5 5-5 5 2.24 5 5-2.24 5-5 5zm0-8c-1.66 0-3 1.34-3 3s1.34 3 3 3 3-1.34 3-3-1.34-3-3-3z" /></svg>
                        MAPEADO DE CURSOS
                    </a>
                    <a asp-action="Create" class="btn-pildora-dashboard">
                        <svg style="width: 16px; fill: white;" viewBox="0 0 24 24"><path d="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z" /></svg>
                        AGREGAR ASIGNATURA
                    </a>
                    <a href="#" class="btn-pildora-dashboard">
                        <svg style="width: 16px; fill: white;" viewBox="0 0 24 24"><path d="M19 3h-1V1h-2v2H8V1H6v2H5c-1.11 0-1.99.9-1.99 2L3 19c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm0 16H5V8h14v11zM7 10h5v5H7z" /></svg>
                        ASIGNAR FECHA DE CORTE
                    </a>
                </div>

                <a asp-action="Index" style="text-align: center; color: black; text-decoration: none; font-weight: 900; font-size: 10px;">
                    <svg style="width: 24px; fill: black; display: block; margin: 0 auto 3px auto;" viewBox="0 0 24 24"><path d="M17.65 6.35C16.2 4.9 14.21 4 12 4c-4.42 0-7.99 3.58-7.99 8s3.57 8 7.99 8c3.73 0 6.84-2.55 7.73-6h-2.08c-.82 2.33-3.04 4-5.65 4-3.31 0-6-2.69-6-6s2.69-6 6-6c1.66 0 3.14.69 4.22 1.78L13 11h7V4l-2.35 2.35z" /></svg>
                    ACTUALIZAR
                </a>
            </div>

            <table class="tabla-dashboard" style="width: 100%;">
                <thead>
                    <tr>
                        <th style="width: 10%;">NO.</th>
                        <th style="width: 30%;">DOCENTE</th>
                        <th style="width: 20%;">ASIGNATURAS</th>
                        <th style="width: 40%;">INDICADORES</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        int contador = 1;
                        foreach (var item in Model)
                        {
                            <tr>
                                <td style="font-size: 16px;">@contador</td>
                                <td style="font-size: 16px; text-transform: uppercase;">DOCENTE @item.Id</td>
                                <td style="font-size: 16px;">@item.UnitNumber</td>
                                <td>
                                    <div style="display: flex; justify-content: space-evenly; align-items: center;">
                                        
                                        <div style="display: flex; flex-direction: column; align-items: center; font-size: 7px; text-transform: uppercase; font-weight: 900;">
                                            <span style="margin-bottom: 5px; line-height: 1.2;">ÍNDICE DE<br>APROBACIÓN</span>
                                            <div style="position: relative; width: 45px; height: 45px;">
                                                <svg viewBox="0 0 36 36" style="width: 100%; height: 100%;">
                                                    <path style="fill:none; stroke:#e6e6e6; stroke-width:4;" d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831" />
                                                    <path style="fill:none; stroke:#112d60; stroke-width:4; stroke-dasharray: @item.ApprovalPercentage, 100;" d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831" />
                                                </svg>
                                                <span style="position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); font-size: 11px;">@item.ApprovalPercentage%</span>
                                            </div>
                                        </div>

                                        <div style="display: flex; flex-direction: column; align-items: center; font-size: 7px; text-transform: uppercase; font-weight: 900;">
                                            <span style="margin-bottom: 5px; line-height: 1.2;">ÍNDICE DE<br>REPROBACIÓN</span>
                                            <div style="position: relative; width: 45px; height: 45px;">
                                                <svg viewBox="0 0 36 36" style="width: 100%; height: 100%;">
                                                    <path style="fill:none; stroke:#e6e6e6; stroke-width:4;" d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831" />
                                                    <path style="fill:none; stroke:#d9534f; stroke-width:4; stroke-dasharray: @item.FailurePercentage, 100;" d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831" />
                                                </svg>
                                                <span style="position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); font-size: 11px;">@item.FailurePercentage%</span>
                                            </div>
                                        </div>

                                        <div style="display: flex; flex-direction: column; align-items: center; font-size: 7px; text-transform: uppercase; font-weight: 900;">
                                            <span style="margin-bottom: 5px; line-height: 1.2;">TASA DE<br>DESERCIÓN</span>
                                            <div style="position: relative; width: 45px; height: 45px;">
                                                <svg viewBox="0 0 36 36" style="width: 100%; height: 100%;">
                                                    <path style="fill:none; stroke:#e6e6e6; stroke-width:4;" d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831" />
                                                    <path style="fill:none; stroke:#cccccc; stroke-width:4; stroke-dasharray: @item.DropoutPercentage, 100;" d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831" />
                                                </svg>
                                                <span style="position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); font-size: 11px;">@item.DropoutPercentage%</span>
                                            </div>
                                        </div>

                                    </div>
                                </td>
                            </tr>
                            contador++;
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="4" style="padding: 40px; color: #666; font-weight: bold; font-size: 16px;">
                                No hay datos de seguimiento registrados actualmente.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>