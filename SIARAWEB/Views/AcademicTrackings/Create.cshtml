@model SIARAWEB.Models.AcademicTracking

@{
    ViewData["Title"] = "Agregar Seguimiento";
    Layout = null; /* Evita que se dupliquen menús si lo usas como ventana flotante */
}

<link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
<link rel="stylesheet" href="~/css/estilos.css" />

<div class="modal-compacto">
    
    <a asp-action="Index" class="btn-cerrar-circulo">&#10005;</a>

    <div class="modal-header-compacto">
        AGREGAR SEGUIMIENTO ACADÉMICO
    </div>

    <form asp-action="Create" style="padding: 25px 30px;">
        <div asp-validation-summary="ModelOnly" class="text-danger" style="font-size: 12px; font-weight: bold; margin-bottom: 15px;"></div>

        <div class="fila-horizontal">
            <label class="label-horizontal">ASIGNATURA</label>
            <div class="input-container-horizontal">
                <select asp-for="SubjectId" class="input-grueso" style="padding: 6px; font-size: 12px;" asp-items="ViewBag.SubjectId">
                    <option value="">Seleccione una asignatura</option>
                </select>
                <span asp-validation-for="SubjectId" class="text-danger" style="font-size: 10px; font-weight: bold;"></span>
            </div>
        </div>

        <div class="fila-horizontal">
            <label class="label-horizontal">UNIDAD</label>
            <div class="input-container-horizontal">
                <input asp-for="UnitNumber" type="number" class="input-grueso" style="padding: 6px; font-size: 12px;" placeholder="Ej. 1" />
                <span asp-validation-for="UnitNumber" class="text-danger" style="font-size: 10px; font-weight: bold;"></span>
            </div>
        </div>

        <div class="fila-horizontal">
            <label class="label-horizontal">FASE</label>
            <div class="input-container-horizontal">
                <input asp-for="Phase" class="input-grueso" style="padding: 6px; font-size: 12px;" placeholder="Ej. Ordinaria / Regularización" />
                <span asp-validation-for="Phase" class="text-danger" style="font-size: 10px; font-weight: bold;"></span>
            </div>
        </div>

        <div class="fila-horizontal">
            <label class="label-horizontal">% APROBACIÓN</label>
            <div class="input-container-horizontal">
                <input asp-for="ApprovalPercentage" type="number" step="0.1" class="input-grueso" style="padding: 6px; font-size: 12px;" placeholder="Ej. 85.5" />
                <span asp-validation-for="ApprovalPercentage" class="text-danger" style="font-size: 10px; font-weight: bold;"></span>
            </div>
        </div>

        <div class="fila-horizontal">
            <label class="label-horizontal">% REPROBACIÓN</label>
            <div class="input-container-horizontal">
                <input asp-for="FailurePercentage" type="number" step="0.1" class="input-grueso" style="padding: 6px; font-size: 12px;" placeholder="Ej. 10.5" />
                <span asp-validation-for="FailurePercentage" class="text-danger" style="font-size: 10px; font-weight: bold;"></span>
            </div>
        </div>

        <div class="fila-horizontal">
            <label class="label-horizontal">% DESERCIÓN</label>
            <div class="input-container-horizontal">
                <input asp-for="DropoutPercentage" type="number" step="0.1" class="input-grueso" style="padding: 6px; font-size: 12px;" placeholder="Ej. 4.0" />
                <span asp-validation-for="DropoutPercentage" class="text-danger" style="font-size: 10px; font-weight: bold;"></span>
            </div>
        </div>

        <div style="display: flex; gap: 15px; justify-content: center; margin-top: 25px;">
            <a asp-action="Index" class="btn-pildora-institucional" style="width: 45%; padding: 8px 0; box-sizing: border-box;">CANCELAR</a>
            <button type="submit" class="btn-pildora-institucional" style="width: 45%; padding: 8px 0; box-sizing: border-box;">GUARDAR</button>
        </div>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
