@model SIARAWEB.Models.AcademicTracking

@{
    ViewData["Title"] = "Agregar Seguimiento";
    Layout = null; /* Mantenemos Layout nulo para que sea una ventana flotante limpia */
}

<link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
<link rel="stylesheet" href="~/css/estilos.css" />

<div style="background-color: #f4f6f9; min-height: 100vh; display: flex; align-items: center; justify-content: center; padding: 20px;">

    <div style="position: relative; width: 100%; max-width: 550px; background-color: #f2f3f5; border-radius: 10px; padding-bottom: 25px; box-shadow: 0 5px 15px rgba(0,0,0,0.2);">
        
        <a asp-action="Index" style="position: absolute; top: -15px; right: -15px; background-color: white; border: 2px solid #d9534f; color: #d9534f; border-radius: 50%; width: 35px; height: 35px; display: flex; justify-content: center; align-items: center; font-weight: bold; text-decoration: none; font-size: 18px; z-index: 10; box-shadow: 0 2px 5px rgba(0,0,0,0.2); cursor: pointer;">&#10005;</a>

        <div style="background-color: #112d60; color: white; text-align: center; font-weight: 900; padding: 15px; border-radius: 8px 8px 0 0; text-transform: uppercase; font-size: 16px;">
            AGREGAR SEGUIMIENTO ACADÉMICO
        </div>

        <form asp-action="Create" style="padding: 25px 40px;">
            
            <div asp-validation-summary="ModelOnly" class="text-danger" style="font-size: 12px; font-weight: bold; margin-bottom: 15px; text-align: center;"></div>

            <div style="display: flex; align-items: center; margin-bottom: 15px;">
                <label asp-for="SubjectId" style="width: 35%; font-weight: 900; font-size: 13px; text-transform: uppercase; text-align: right; padding-right: 15px;">ASIGNATURA</label>
                <div style="width: 65%;">
                    <select asp-for="SubjectId" style="width: 100%; border: 2px solid #000; padding: 6px; font-size: 12px; font-weight: bold; text-transform: uppercase;" asp-items="ViewBag.SubjectId">
                        <option value="">Seleccione una asignatura</option>
                    </select>
                    <span asp-validation-for="SubjectId" class="text-danger" style="font-size: 10px; font-weight: bold;"></span>
                </div>
            </div>

            <div style="display: flex; align-items: center; margin-bottom: 15px;">
                <label asp-for="UnitNumber" style="width: 35%; font-weight: 900; font-size: 13px; text-transform: uppercase; text-align: right; padding-right: 15px;">UNIDAD</label>
                <div style="width: 65%;">
                    <input asp-for="UnitNumber" type="number" style="width: 100%; border: 2px solid #000; padding: 6px; font-size: 12px; font-weight: bold; text-align: center;" placeholder="Ej. 1" />
                    <span asp-validation-for="UnitNumber" class="text-danger" style="font-size: 10px; font-weight: bold;"></span>
                </div>
            </div>

            <div style="display: flex; align-items: center; margin-bottom: 15px;">
                <label asp-for="Phase" style="width: 35%; font-weight: 900; font-size: 13px; text-transform: uppercase; text-align: right; padding-right: 15px;">FASE</label>
                <div style="width: 65%;">
                    <input asp-for="Phase" style="width: 100%; border: 2px solid #000; padding: 6px; font-size: 12px; font-weight: bold; text-transform: uppercase;" placeholder="Ordinaria / Reg." />
                    <span asp-validation-for="Phase" class="text-danger" style="font-size: 10px; font-weight: bold;"></span>
                </div>
            </div>

            <div style="display: flex; align-items: center; margin-bottom: 15px;">
                <label asp-for="ApprovalPercentage" style="width: 35%; font-weight: 900; font-size: 13px; text-transform: uppercase; text-align: right; padding-right: 15px;">% APROBACIÓN</label>
                <div style="width: 65%;">
                    <input asp-for="ApprovalPercentage" type="number" step="0.1" style="width: 100%; border: 2px solid #000; padding: 6px; font-size: 12px; font-weight: bold; text-align: center;" placeholder="Ej. 85.5" />
                    <span asp-validation-for="ApprovalPercentage" class="text-danger" style="font-size: 10px; font-weight: bold;"></span>
                </div>
            </div>

            <div style="display: flex; align-items: center; margin-bottom: 15px;">
                <label asp-for="FailurePercentage" style="width: 35%; font-weight: 900; font-size: 13px; text-transform: uppercase; text-align: right; padding-right: 15px;">% REPROBACIÓN</label>
                <div style="width: 65%;">
                    <input asp-for="FailurePercentage" type="number" step="0.1" style="width: 100%; border: 2px solid #000; padding: 6px; font-size: 12px; font-weight: bold; text-align: center;" placeholder="Ej. 10.5" />
                    <span asp-validation-for="FailurePercentage" class="text-danger" style="font-size: 10px; font-weight: bold;"></span>
                </div>
            </div>

            <div style="display: flex; align-items: center; margin-bottom: 25px;">
                <label asp-for="DropoutPercentage" style="width: 35%; font-weight: 900; font-size: 13px; text-transform: uppercase; text-align: right; padding-right: 15px;">% DESERCIÓN</label>
                <div style="width: 65%;">
                    <input asp-for="DropoutPercentage" type="number" step="0.1" style="width: 100%; border: 2px solid #000; padding: 6px; font-size: 12px; font-weight: bold; text-align: center;" placeholder="Ej. 4.0" />
                    <span asp-validation-for="DropoutPercentage" class="text-danger" style="font-size: 10px; font-weight: bold;"></span>
                </div>
            </div>

            <div style="display: flex; gap: 20px; justify-content: center; margin-top: 15px;">
                <a asp-action="Index" class="btn-siara-3d" style="width: 45%; background: linear-gradient(to bottom, #999, #666) !important; border-color: #555 !important; text-decoration: none; text-align: center;">CANCELAR</a>
                <button type="submit" class="btn-siara-3d" style="width: 45%;">GUARDAR</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}