@model SIARAWEB.Models.AcademicTracking

@{
    ViewData["Title"] = "Eliminar Seguimiento";
    Layout = null; /* Evita menús duplicados si se usa como modal */
}

<link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
<link rel="stylesheet" href="~/css/estilos.css" />

<div class="modal-compacto" style="border: 2px solid #d9534f; overflow: hidden;">
    
    <a asp-action="Index" class="btn-cerrar-circulo">&#10005;</a>

    <div class="modal-header-compacto" style="background-color: #d9534f;">
        ELIMINAR SEGUIMIENTO ACADÉMICO
    </div>

    <div style="padding: 25px 30px;">
        
        <h4 style="color: #d9534f; font-weight: 900; text-align: center; margin-bottom: 10px;">¿ESTÁS SEGURO?</h4>
        <p style="font-weight: bold; color: #555; text-align: center; margin-bottom: 25px; font-size: 13px;">
            ¿Realmente deseas eliminar este registro de seguimiento? Esta acción no se puede deshacer.
        </p>

        <div class="fila-horizontal">
            <label class="label-horizontal">ASIGNATURA</label>
            <div class="input-container-horizontal">
                <div style="background-color: #fce4e4; border: 2px solid #f5c6c6; border-radius: 5px; padding: 6px 10px; font-weight: 900; font-size: 12px; color: #d9534f;">
                    @Html.DisplayFor(model => model.Subject.Id)
                </div>
            </div>
        </div>

        <div class="fila-horizontal">
            <label class="label-horizontal">UNIDAD</label>
            <div class="input-container-horizontal">
                <div style="background-color: #fce4e4; border: 2px solid #f5c6c6; border-radius: 5px; padding: 6px 10px; font-weight: 900; font-size: 12px; color: #d9534f;">
                    @Model.UnitNumber
                </div>
            </div>
        </div>

        <div class="fila-horizontal">
            <label class="label-horizontal">FASE</label>
            <div class="input-container-horizontal">
                <div style="background-color: #fce4e4; border: 2px solid #f5c6c6; border-radius: 5px; padding: 6px 10px; font-weight: 900; font-size: 12px; color: #d9534f;">
                    @Model.Phase
                </div>
            </div>
        </div>

        <div class="fila-horizontal">
            <label class="label-horizontal">% APROB.</label>
            <div class="input-container-horizontal">
                <div style="background-color: #fce4e4; border: 2px solid #f5c6c6; border-radius: 5px; padding: 6px 10px; font-weight: 900; font-size: 12px; color: #d9534f;">
                    @Model.ApprovalPercentage %
                </div>
            </div>
        </div>

        <div class="fila-horizontal">
            <label class="label-horizontal">% REPROB.</label>
            <div class="input-container-horizontal">
                <div style="background-color: #fce4e4; border: 2px solid #f5c6c6; border-radius: 5px; padding: 6px 10px; font-weight: 900; font-size: 12px; color: #d9534f;">
                    @Model.FailurePercentage %
                </div>
            </div>
        </div>

        <div class="fila-horizontal">
            <label class="label-horizontal">% DESERCIÓN</label>
            <div class="input-container-horizontal">
                <div style="background-color: #fce4e4; border: 2px solid #f5c6c6; border-radius: 5px; padding: 6px 10px; font-weight: 900; font-size: 12px; color: #d9534f;">
                    @Model.DropoutPercentage %
                </div>
            </div>
        </div>

        <form asp-action="Delete" style="display: flex; gap: 15px; justify-content: center; margin-top: 25px;">
            <input type="hidden" asp-for="Id" />
            
            <a asp-action="Index" class="btn-pildora-institucional" style="width: 45%; padding: 8px 0; background: linear-gradient(to bottom, #999, #666) !important; border-color: #555 !important;">CANCELAR</a>
            
            <button type="submit" class="btn-pildora-institucional" style="width: 45%; padding: 8px 0; background: linear-gradient(to bottom, #d9534f, #c9302c) !important; border-color: #ac2925 !important;">ELIMINAR</button>
        </form>
    </div>
</div>